# ===========================================
# Backend Selection
# ===========================================
# "local" runs fully offline (no API keys needed) using sentence-transformers
# and an in-memory vector store. Switch to "cohere"/"pinecone" to use APIs.
EMBEDDING_BACKEND=local
VECTOR_BACKEND=local
RERANK_BACKEND=local

# ===========================================
# Local Model Configuration (used when backend=local)
# ===========================================
LOCAL_EMBED_MODEL=intfloat/multilingual-e5-small
LOCAL_RERANK_MODEL=cross-encoder/mmarco-mMiniLMv2-L12-H384-v1

# ===========================================
# Cohere Configuration (optional — only when EMBEDDING_BACKEND=cohere)
# ===========================================
# COHERE_API_KEY=your-cohere-api-key-here
COHERE_EMBED_MODEL=embed-multilingual-v3.0
COHERE_RERANK_MODEL=rerank-v3.5

# ===========================================
# Pinecone Configuration (optional — only when VECTOR_BACKEND=pinecone)
# ===========================================
# PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=cse-scanner

# ===========================================
# Scanner Configuration
# ===========================================
DUPLICATE_THRESHOLD=0.92
MIN_SENTENCE_LENGTH=10
MAX_SENTENCE_LENGTH=2000
BATCH_SIZE=96

# ===========================================
# Evaluation Configuration
# ===========================================
TOP_K=10
EMBED_DIMENSION=1024

# ===========================================
# Logging Configuration
# ===========================================
LOG_LEVEL=INFO
